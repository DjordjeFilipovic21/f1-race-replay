{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:f1-cache-replay:schema:replay-data:v1:chunk",
  "title": "Replay data chunk",
  "description": "Schema for a committed replay chunk in the Phase 0 v1 offline replay contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "fixtureId",
    "chunkId",
    "sequence",
    "startMs",
    "endMs",
    "overlap",
    "samples",
    "events"
  ],
  "$defs": {
    "driverCode": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,4}$"
    },
    "sessionTimeMs": {
      "type": "integer",
      "minimum": 0
    },
    "nullableNumber": {
      "type": [
        "number",
        "null"
      ]
    },
    "timeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startMs",
        "endMs"
      ],
      "properties": {
        "startMs": {
          "$ref": "#/$defs/sessionTimeMs"
        },
        "endMs": {
          "$ref": "#/$defs/sessionTimeMs"
        }
      }
    },
    "chunkFileReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "path",
        "schemaId",
        "startMs",
        "endMs",
        "overlapWithPreviousMs"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "path": {
          "type": "string",
          "pattern": "^chunks/chunk-[0-9]{3}\\.json$"
        },
        "schemaId": {
          "const": "urn:f1-cache-replay:schema:replay-data:v1:chunk"
        },
        "startMs": {
          "$ref": "#/$defs/sessionTimeMs"
        },
        "endMs": {
          "$ref": "#/$defs/sessionTimeMs"
        },
        "overlapWithPreviousMs": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "overlapNone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "previousChunkPath",
        "range",
        "authoritativeFromMs"
      ],
      "properties": {
        "kind": {
          "const": "none"
        },
        "previousChunkPath": {
          "type": "null"
        },
        "range": {
          "type": "null"
        },
        "authoritativeFromMs": {
          "type": "null"
        }
      }
    },
    "overlapHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "previousChunkPath",
        "range",
        "authoritativeFromMs"
      ],
      "properties": {
        "kind": {
          "const": "handoff"
        },
        "previousChunkPath": {
          "type": "string",
          "pattern": "^chunks/chunk-[0-9]{3}\\.json$"
        },
        "range": {
          "$ref": "#/$defs/timeRange"
        },
        "authoritativeFromMs": {
          "$ref": "#/$defs/sessionTimeMs"
        }
      }
    },
    "driverSample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "trackDistanceMeters",
        "lap",
        "position",
        "gear",
        "drs",
        "tyreCompound",
        "status"
      ],
      "properties": {
        "x": {
          "$ref": "#/$defs/nullableNumber"
        },
        "y": {
          "$ref": "#/$defs/nullableNumber"
        },
        "trackDistanceMeters": {
          "$ref": "#/$defs/nullableNumber"
        },
        "speed": {
          "$ref": "#/$defs/nullableNumber"
        },
        "throttle": {
          "$ref": "#/$defs/nullableNumber"
        },
        "brake": {
          "$ref": "#/$defs/nullableNumber"
        },
        "gapToLeaderMs": {
          "$ref": "#/$defs/nullableNumber"
        },
        "lap": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "position": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "gear": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 8
        },
        "drs": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "tyreCompound": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "status": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "isInPitLane": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessionTimeMs",
        "sampleRole",
        "leaderboardOrder",
        "trackStatusCode",
        "weatherState",
        "drivers"
      ],
      "properties": {
        "sessionTimeMs": {
          "$ref": "#/$defs/sessionTimeMs"
        },
        "sampleRole": {
          "enum": [
            "authoritative",
            "overlap_reference"
          ]
        },
        "leaderboardOrder": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/driverCode"
          }
        },
        "trackStatusCode": {
          "type": "integer",
          "minimum": 0
        },
        "weatherState": {
          "type": "string",
          "minLength": 1
        },
        "drivers": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/driverCode"
          },
          "additionalProperties": {
            "$ref": "#/$defs/driverSample"
          }
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessionTimeMs",
        "eventType",
        "description"
      ],
      "properties": {
        "sessionTimeMs": {
          "$ref": "#/$defs/sessionTimeMs"
        },
        "eventType": {
          "type": "string",
          "minLength": 1
        },
        "driverId": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z0-9]{2,4}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "chunk001": {
      "properties": {
        "chunkId": {
          "const": "chunk-001"
        },
        "sequence": {
          "const": 1
        },
        "overlap": {
          "$ref": "#/$defs/overlapNone"
        }
      }
    },
    "chunk002": {
      "properties": {
        "chunkId": {
          "const": "chunk-002"
        },
        "sequence": {
          "const": 2
        },
        "overlap": {
          "allOf": [
            {
              "$ref": "#/$defs/overlapHandoff"
            },
            {
              "properties": {
                "previousChunkPath": {
                  "const": "chunks/chunk-001.json"
                }
              }
            }
          ]
        }
      }
    }
  },
  "properties": {
    "contractVersion": {
      "const": "v1"
    },
    "fixtureId": {
      "const": "deterministic-race"
    },
    "chunkId": {
      "type": "string",
      "pattern": "^chunk-[0-9]{3}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "startMs": {
      "$ref": "#/$defs/sessionTimeMs"
    },
    "endMs": {
      "$ref": "#/$defs/sessionTimeMs"
    },
    "overlap": {
      "oneOf": [
        {
          "$ref": "#/$defs/overlapNone"
        },
        {
          "$ref": "#/$defs/overlapHandoff"
        }
      ]
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sample"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/chunk001"
    },
    {
      "$ref": "#/$defs/chunk002"
    }
  ]
}
